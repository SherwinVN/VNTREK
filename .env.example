# ── Dev server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=debug

# ── Initial admin account (first boot only) ──────────────────────────────────
ADMIN_EMAIL=admin@trek.local
ADMIN_PASSWORD=changeme

# ── Encryption (auto-generated if unset) ─────────────────────────────────────
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ── Session ──────────────────────────────────────────────────────────────────
# SESSION_DURATION=30d
# SESSION_DURATION_REMEMBER=90d

# ── Language ─────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=vi

# ── CORS / TLS ───────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:5173
# FORCE_HTTPS=false
# COOKIE_SECURE=false
# TRUST_PROXY=0

# ── Demo mode (resets data hourly) ───────────────────────────────────────────
# DEMO_MODE=false

# ── MCP ──────────────────────────────────────────────────────────────────────
# MCP_RATE_LIMIT=300
# MCP_MAX_SESSION_PER_USER=20

# ── Overpass (map POI search) ────────────────────────────────────────────────
# OVERPASS_URL=
# OVERPASS_TIMEOUT_MS=12000

# ── Backup ───────────────────────────────────────────────────────────────────
# BACKUP_UPLOAD_LIMIT_MB=500

# ── OIDC ─────────────────────────────────────────────────────────────────────
# APP_URL=http://localhost:3001
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISPLAY_NAME=SSO
# OIDC_ONLY=false
# OIDC_ADMIN_CLAIM=groups
# OIDC_ADMIN_VALUE=app-trek-admins
# OIDC_SCOPE=openid email profile
# OIDC_DISCOVERY_URL=
